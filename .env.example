# Connexion au serveur Unraid (GraphQL)
UNRAID_GRAPHQL_URL=http://<ip-unraid>/graphql
UNRAID_API_KEY=<votre-x-api-key>

# Port du serveur API/dashboard
PORT=3000

# Optionnel : si défini, l'API exige Authorization: Bearer <token>
# (et le terminal WebSocket exige ?token=<token>)
API_TOKEN=

# Terminal interactif (shell root via WebSocket sur /api/terminal)
# TERMINAL_DISABLED=1   # pour le désactiver complètement
# TERMINAL_CWD=/mnt/user   # dossier de départ du shell (défaut: /mnt/user)
